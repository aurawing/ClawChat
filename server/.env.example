# ClawChat Proxy example config
# Actual runtime config is loaded from ~/.clawchat-proxy

# Proxy server port
PROXY_PORT=18888

# OpenClaw Gateway URL
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw Gateway token auth
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw Gateway password auth (takes priority over token)
OPENCLAW_GATEWAY_PASSWORD=

# Download roots whitelist
DOWNLOAD_ROOTS=~/.openclaw/workspace/sessions

# Multi-user accounts: username:password,username2:password2
# Username must not contain colon, password should not contain comma
PROXY_USERS=alice:password1,bob:password2

# Optional path mapping from virtual path to local path
DOWNLOAD_PATH_MAPS=

# Log level: error / warn / info / debug / trace
LOG_LEVEL=info

# Allowed CORS origins, leave empty to allow all
ALLOWED_ORIGINS=
