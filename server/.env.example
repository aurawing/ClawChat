# ClawChat 浠ｇ悊鏈嶅姟閰嶇疆

# 浠ｇ悊鏈嶅姟绔彛
PORT=3210

# OpenClaw Gateway 鍦板潃锛堥粯璁ゆ湰鏈猴級
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw Gateway Token
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# 浠ｇ悊鏈嶅姟 Token锛堝鎴风杩炴帴鏃堕渶瑕佹彁渚涳級
PROXY_TOKEN=your-proxy-token-here

# 浠ｇ悊鏈嶅姟瀵嗙爜锛堝彲閫夛級
PROXY_PASSWORD=

# 鍏佽鐨勬枃浠朵笂浼犲ぇ灏忥紙MB锛?MAX_FILE_SIZE=20
